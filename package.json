{
  "name": "saas-events",
  "version": "4.0.0",
  "private": true,
  "description": "SaaS Événementiel & Billetterie – plateforme tout-en-un pour organisateurs africains (v4.0.0 RustFS+Docker)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @saas-events/api prisma migrate dev",
    "db:generate": "pnpm --filter @saas-events/api prisma generate",
    "db:studio": "pnpm --filter @saas-events/api prisma studio",
    "db:seed": "pnpm --filter @saas-events/api db:seed",
    "test:unit": "pnpm --filter @saas-events/api test",
    "test:cov": "pnpm --filter @saas-events/api test:cov",
    "test:e2e": "pnpm --filter @saas-events/web test:e2e",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
