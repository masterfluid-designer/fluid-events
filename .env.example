# ============ PROJECT VERSION ============
# SaaS Événementiel & Billetterie v4.0.0
# Couche de stockage S3-compatible (RustFS dev / Supabase Storage prod)
PROJECT_VERSION="4.0.0"

# ============ ENVIRONMENT ============
NODE_ENV=development

# ============ DATABASE ============
# Dev: PostgreSQL Docker (user:password@host:port)
# Prod: Supabase PostgreSQL
DATABASE_URL="postgresql://fluid_user:fluid_password_dev@postgres:5432/fluid_events?schema=public"

# ============ REDIS ============
# Dev: Redis Docker (localhost:6379)
# Prod: Upstash Redis ou Redis managé
REDIS_URL="redis://redis:6379"

# ============ JWT & AUTHENTICATION ============
JWT_SECRET="dev-jwt-secret-change-in-production-min-32-chars-here!!!"
JWT_EXPIRATION=86400
JWT_ALGORITHM="HS256"

# ============ GOOGLE OAUTH ============
GOOGLE_CLIENT_ID="265821009101-ivvncj6de8pqcag9r8g7fl8jmbb92ttt.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ============ STORAGE S3-COMPATIBLE ============
# Dev: RustFS via AWS SDK S3 (endpoint http://rustfs:9000)
# Prod: Supabase Storage via AWS SDK S3 (https://xxxxx.supabase.co)
STORAGE_ENDPOINT="http://rustfs:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="fluid-events"
STORAGE_REGION="us-east-1"
STORAGE_USE_PATH_STYLE_ENDPOINT="true"

# ============ EMAIL (SMTP) ============
# Dev: Mailpit local (port 1025)
# Prod: Resend SMTP ou SendGrid
SMTP_HOST="mailpit"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@fluid-events.dev"
SMTP_SECURE="false"

# ============ WHATSAPP (Twilio) ============
# Pour notifications WhatsApp (V1)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ============ PAYMENT PROVIDERS ============
# Kkiapay (Cameroun, Côte d'Ivoire)
KKIAPAY_API_KEY=""
KKIAPAY_WEBHOOK_SECRET=""

# CinetPay (Afrique)
CINETPAY_API_KEY=""
CINETPAY_WEBHOOK_SECRET=""

# FedaPay (Afrique)
FEDAPAY_API_KEY=""
FEDAPAY_WEBHOOK_SECRET=""

# ============ APP URLS ============
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
API_INTERNAL_URL="http://api:4000"

# ============ PDF GENERATION (Puppeteer) ============
PDF_TIMEOUT=30000
PDF_FORMAT="A4"
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD="false"

# ============ QR CODE ============
# Signature HS256 pour QR codes (anti-tampering)
QR_SECRET="qr-secret-min-32-chars-change-in-prod-here!!!!!"

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SCAN_WINDOW_MS=60000
RATE_LIMIT_SCAN_MAX_REQUESTS=30

# ============ LOGGING ============
LOG_LEVEL="debug"
LOG_FORMAT="json"

# ============ SECURITY ============
# CORS & CSP
CORS_ORIGIN="http://localhost:3000"
ALLOW_ORIGINS="http://localhost:3000,http://localhost:3001"

# Helmet headers
HSTS_MAX_AGE=31536000
HSTS_PRELOAD="false"

# ============ FEATURE FLAGS ============
FEATURE_WHATSAPP_NOTIFICATIONS="true"
FEATURE_WEBHOOK_RETRIES="true"
FEATURE_ASYNC_PDF_GENERATION="true"

# ============ BULLMQ (Job Queue) ============
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_DEFAULT_BACKOFF_DELAY=5000
