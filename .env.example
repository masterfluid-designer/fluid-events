# ============ ENVIRONMENT ============
NODE_ENV=development

# ============ DATABASE ============
# Dev: PostgreSQL Docker
# Prod: Supabase PostgreSQL
DATABASE_URL="postgresql://user:password@postgres:5432/fluid_events?schema=public"

# ============ REDIS ============
# Dev: Redis Docker
# Prod: Upstash Redis ou Redis managé
REDIS_URL="redis://redis:6379"

# ============ JWT & TOKENS ============
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here!!!!!!"
JWT_EXPIRATION="7d"

# ============ GOOGLE OAUTH ============
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ============ STORAGE S3-COMPATIBLE ============
# Dev: RustFS via AWS SDK S3 (endpoint localhost:9000)
# Prod: Supabase Storage via AWS SDK S3
STORAGE_ENDPOINT="http://rustfs:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="fluid-events"
STORAGE_REGION="us-east-1"

# ============ EMAIL (SMTP) ============
# Dev: Mailpit local (smtp://mailpit:1025)
# Prod: Resend via SMTP
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@fluid-events.com"

# ============ WHATSAPP ============
WHATSAPP_API_URL="https://api.whatsapp.com/send"
WHATSAPP_TOKEN="your-whatsapp-business-token"

# ============ PAYMENT PROVIDERS ============
KKIAPAY_API_KEY="your-kkiapay-api-key"
KKIAPAY_WEBHOOK_SECRET="your-kkiapay-webhook-secret"

CINETPAY_API_KEY="your-cinetpay-api-key"
CINETPAY_WEBHOOK_SECRET="your-cinetpay-webhook-secret"

FEDAPAY_API_KEY="your-fedapay-api-key"
FEDAPAY_WEBHOOK_SECRET="your-fedapay-webhook-secret"

# ============ APP URLS ============
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
API_INTERNAL_URL="http://api:4000"

# ============ PDF GENERATION ============
PDF_TIMEOUT="30000"
PDF_FORMAT="A4"

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# ============ LOG LEVEL ============
LOG_LEVEL="debug"
